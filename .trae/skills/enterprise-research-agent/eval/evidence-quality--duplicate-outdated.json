    },
    "graph": {
      "entities": [
        { "id": "e1", "type": "Vendor", "name": "RiskConcile", "properties": {} }
      ],
      "evidence": [
        {
          "id": "ev1",
          "source": "GitHub",
          "entityId": "e1",
          "content": "CODEOWNERS says Team A",
          "lastUpdated": "2026-07-19",
          "sourceMetadata": { "type": "system_of_record", "authority": 0.85, "independence": 1.0 },
          "claims": [{ "property": "owner", "value": "Team A" }]
        },
        {
          "id": "ev2",
          "source": "GitHub",
          "entityId": "e1",
          "content": "CODEOWNERS says Team A",
          "lastUpdated": "2026-07-19",
          "sourceMetadata": { "type": "system_of_record", "authority": 0.85, "independence": 1.0 },
          "claims": [{ "property": "owner", "value": "Team A" }]
        },
        {
          "id": "ev3",
